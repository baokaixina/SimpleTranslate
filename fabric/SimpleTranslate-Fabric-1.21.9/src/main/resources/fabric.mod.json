{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
    "${mod_authors}"
  ],
  "license": "${mod_license}",
  "icon": "assets/simple_translate/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.yourname.simpletranslate.SimpleTranslateServerMod"
    ],
    "client": [
      "com.yourname.simpletranslate.SimpleTranslateMod"
    ],
    "modmenu": [
      "com.yourname.simpletranslate.compat.ModMenuIntegration"
    ]
  },
  "mixins": [
    "simple_translate.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": ">=${minecraft_version}",
    "fabric-api": ">=${fabric_version}"
  },
  "suggests": {
    "modmenu": "*"
  }
}
